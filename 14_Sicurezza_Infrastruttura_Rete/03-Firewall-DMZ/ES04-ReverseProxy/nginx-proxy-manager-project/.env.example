# ==============================================
# Nginx Proxy Manager - Environment Variables
# ==============================================

# Versione NPM
NPM_VERSION=latest

# Porte esposte
HTTP_PORT=80
HTTPS_PORT=443
ADMIN_PORT=81

# Timezone
TZ=Europe/Rome

# Database (se usi MySQL/MariaDB esterno)
# DB_ROOT_PASSWORD=SecureRootPassword123!
# DB_PASSWORD=NpmPassword456!

# Email per Let's Encrypt (CAMBIA!)
LETSENCRYPT_EMAIL=admin@example.com

# Opzioni avanzate
# DISABLE_IPV6=true
# PUID=1000
# PGID=1000
